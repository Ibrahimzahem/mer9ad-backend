# Copy to .env and fill in your key. Never commit the real .env file.
#
# Variant of .env.example that routes BOTH AI stages through OpenRouter —
# no Groq key needed at all. Useful if you don't have a Groq key, or want
# a single provider/billing surface for the whole demo.
#
# Trade-off: the investigator (ReAct tool-calling loop) will be noticeably
# slower than Groq's ~500 tok/s LPU inference, since it makes several
# round-trips per assessment (plan -> tool call -> observe -> repeat).
# Tool calling itself is unaffected — the harness is provider-agnostic and
# just needs a model that supports OpenAI-style function calling (the
# default below does).

# --- Judge stage (final verdict-writer, ai/OpenRouterShieldAi) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.2

# --- Investigator stage (ReAct harness: ReasoningFraudAgent, AmlAgent) ---
# Reuses OPENROUTER_API_KEY above. Pick any OpenRouter model that supports tool calling.
SHIELD_AI=openrouter
OPENROUTER_REASONING_MODEL=google/gemini-2.5-flash

# --- Optional tools ---
TAVILY_API_KEY=
