# Copy to .env and fill in your keys. Never commit the real .env file.
#
# Shield has two independent AI stages:
#   1. Judge (writes the final verdict)        -> configured by OPENROUTER_API_KEY / OLLAMA_*
#   2. Investigator (ReAct harness with tools)  -> configured by SHIELD_AI + matching key
#
# This is the default setup: Groq for the fast tool-calling investigator,
# OpenRouter for the judge. See .env.openrouter.example to run BOTH stages
# through OpenRouter instead.

# --- Judge stage (final verdict-writer, ai/OpenRouterShieldAi) ---
# Leave OPENROUTER_API_KEY blank to fall back to the deterministic StubShieldAi (offline demo mode).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.2

# --- Investigator stage (ReAct harness: ReasoningFraudAgent, AmlAgent) ---
# Values: ollama | groq | openrouter | (unset = harness disabled, agents use deterministic fallback rules)
SHIELD_AI=groq

# Required when SHIELD_AI=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Optional tools ---
# Web-search tool available to reasoning agents (agent/WebSearchTool.java). Omit to disable.
TAVILY_API_KEY=
